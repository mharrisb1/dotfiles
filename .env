export EDITOR="hx"
export HELIX_RUNTIME="$HOME/helix/runtime"
export PATH="$HOME/.cargo/bin:/usr/local/go/bin:$HOME/go/bin:$PATH"

if [ -d "$HOME/.nvm/versions/node" ]; then
    _NVM_BIN_PATH=$(ls -d $HOME/.nvm/versions/node/*/bin 2>/dev/null | sort -V | tail -n 1)
    if [ -n "$_NVM_BIN_PATH" ]; then
        export PATH="$_NVM_BIN_PATH:$PATH"
    fi
    unset _NVM_BIN_PATH
fi

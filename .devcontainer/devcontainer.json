{
  "$schema": "https://raw.githubusercontent.com/devcontainers/spec/refs/heads/main/schemas/devContainer.schema.json",
  "name": "Dev Container",
  "runArgs": [
    "--name",
    "devcontainer"
  ],
  "build": {
    "dockerfile": "Dockerfile",
    "context": "..",
    "args": {
      "OS_VERSION": "${localEnv:OS_VERSION}"
    }
  },
  "containerUser": "developer",
  "remoteUser": "developer",
  "updateRemoteUserUID": true,
  "mounts": [
    "source=${localWorkspaceFolder},target=/home/developer/workspace/${localWorkspaceFolderBasename},type=bind",
    "source=${localEnv:HOME}/.ssh,target=/home/developer/.ssh,type=bind,readonly"
  ],
  "workspaceFolder": "/home/developer/workspace/${localWorkspaceFolderBasename}",
  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
      "version": "latest",
      "enableNonRootDocker": "true"
    }
  }
}